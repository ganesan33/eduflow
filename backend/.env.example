PORT=3000
MONGODB_URI=mongodb://your-cosmosdb-account:YOUR_KEY_HERE@your-cosmosdb-account.mongo.cosmos.azure.com:10255/eduflow?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000
NODE_ENV=production
JWT_ACCESS_SECRET=replace-with-a-strong-random-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-refresh-secret-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=https://eduflow-frontend.azurewebsites.net
APP_BASE_URL=https://eduflow-frontend.azurewebsites.net

# Email Configuration (Optional - for email verification and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=your-email@gmail.com

# Azure Blob Storage (for course videos and thumbnails)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=eduflow-media
AZURE_SAS_EXPIRY_MINUTES=60
